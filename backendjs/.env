# Réseau
PORT=4001

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/myapp

# JWT
JWT_SECRET=ChangeThisSuperSecretJwtKey
# Tokens d'accès
JWT_EXPIRES=15m
REFRESH_EXPIRES=7d
# MFA
ISSUER_NAME=SecureDocsApp    # nom affiché dans Google Authenticator
PEPPER=PutARandomLongPepperHere

# Verrouillage :
LOCK_WINDOW_MINUTES=15    # durée du lock après 5 échecs
